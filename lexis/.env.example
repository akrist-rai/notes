# Copy this file to .env and fill in your keys
FIRECRAWL_API_KEY=your_firecrawl_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# Optional: override the Claude model (default: claude-3-5-sonnet-20241022)
# LEXIS_MODEL=claude-3-5-sonnet-20241022

# Optional: crawl depth limit (default: 2)
# LEXIS_CRAWL_DEPTH=2

# Optional: max pages per crawl (default: 10)
# LEXIS_MAX_PAGES=10
